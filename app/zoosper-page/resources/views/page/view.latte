{* Module-owned CMS page view. The body HTML is prepared by PageRenderer. *}
<article class="cms-page page-shell cms-page--module-view">
    <header class="cms-page__header">
        <h1>{$page->title ?? ''}</h1>
    </header>

    <div class="cms-page__content">
        {($renderedContent ?? $page->content ?? '')|noescape}
    </div>
</article>
