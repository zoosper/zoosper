APP_NAME=Zoosper
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080
APP_KEY=change-me-before-production

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
DB_DATABASE=storage/database/zoosper.sqlite

# MySQL example
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=zoosper
# DB_USERNAME=root
# DB_PASSWORD=secret

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------
SESSION_NAME=ZOOSPERSESSID
SESSION_SECURE=false
SESSION_SAMESITE=Lax

# -----------------------------------------------------------------------------
# Default site
# -----------------------------------------------------------------------------
DEFAULT_SITE_CODE=main
DEFAULT_SITE_NAME="Main Website"
DEFAULT_SITE_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# Version
# -----------------------------------------------------------------------------
CMS_VERSION=0.8.0-dev

# -----------------------------------------------------------------------------
# Static assets
# -----------------------------------------------------------------------------
# Keep static paths separate from application routes such as /admin.
ASSET_BASE_PATH=/assets
ADMIN_ASSET_PATH=/assets/admin
FRONTEND_ASSET_PATH=/assets/frontend
MODULE_ASSET_PATH=/assets/modules

# -----------------------------------------------------------------------------
# Admin large-content editor
# -----------------------------------------------------------------------------
# Keep disabled by default until editor assets and content sanitisation are wired.
ADMIN_WYSIWYG_ENABLED=false
ADMIN_WYSIWYG_PROVIDER=editorjs
ADMIN_WYSIWYG_STORE_FORMAT=json

# -----------------------------------------------------------------------------
# Admin tag selector
# -----------------------------------------------------------------------------
# Progressive enhancement for safe tag-style multi-selection.
ADMIN_TAG_SELECTOR_ENABLED=true
ADMIN_TAG_SELECTOR_MAX_VISIBLE_OPTIONS=25

# -----------------------------------------------------------------------------
# Mail / SMTP
# -----------------------------------------------------------------------------
# Keep SMTP passwords in environment variables or secret storage only.
# Do not commit real SMTP credentials.
MAIL_TRANSPORT=smtp
MAIL_FROM_ADDRESS=no-reply@example.test
MAIL_FROM_NAME=Zoosper

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=
SMTP_TIMEOUT_SECONDS=15
