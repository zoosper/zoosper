#!/usr/bin/env php
<?php

declare(strict_types=1);

use Zoosper\Auth\Repository\AdminUserRepository;
use Zoosper\Auth\Service\PasswordHasher;
use Zoosper\Core\Config\ConfigRepository;
use Zoosper\Core\Database\ConnectionFactory;
use Zoosper\Core\Database\Migrator;
use Zoosper\Core\Scaffold\ModuleScaffolder;
use Zoosper\Page\Repository\PageRepository;
use Zoosper\Site\Repository\SiteRepository;

require dirname(__DIR__) . '/bootstrap/autoload.php';

$basePath = dirname(__DIR__);
$config = ConfigRepository::fromPath($basePath . '/config');
$pdo = (new ConnectionFactory($config, $basePath))->create();
$command = $argv[1] ?? 'help';
$options = parseOptions(array_slice($argv, 2));

if ($command === 'migrate') {
    (new Migrator($pdo, $basePath . '/database/migrations'))->migrate();
    echo "Zoosper migrations completed.\n";
    exit(0);
}

if ($command === 'make:module') {
    $moduleName = $argv[2] ?? '';
    $result = (new ModuleScaffolder($basePath))->scaffold($moduleName);

    echo "Created module {$result->moduleName}\n";
    echo "Namespace: {$result->namespace}\n";
    echo "Path: {$result->modulePath}\n";
    echo "Files:\n";
    foreach ($result->createdFiles as $file) {
        echo "  - {$file}\n";
    }
    echo "\nNext: add the PSR-4 autoload snippet from {$result->modulePath}/README.md if you add PHP classes.\n";
    exit(0);
}

if ($command === 'admin:create') {
    $email = required($options, 'email');
    $password = required($options, 'password');
    $name = $options['name'] ?? 'Admin User';

    $users = new AdminUserRepository($pdo);

    if ($users->findByEmail($email) !== null) {
        fwrite(STDERR, "Admin user already exists: {$email}\n");
        exit(1);
    }

    $id = $users->create($email, $name, (new PasswordHasher())->hash($password), 'super_admin');
    echo "Created super admin user #{$id}: {$email}\n";
    exit(0);
}

if ($command === 'site:create') {
    $code = $options['code'] ?? (string) env('DEFAULT_SITE_CODE', 'main');
    $name = $options['name'] ?? (string) env('DEFAULT_SITE_NAME', 'Main Website');
    $host = $options['host'] ?? (string) env('DEFAULT_SITE_HOST', '127.0.0.1');
    $homepageSlug = $options['homepage'] ?? 'home';

    $sites = new SiteRepository($pdo);
    $id = $sites->create($code, $name, $host, $homepageSlug);

    echo "Created site #{$id}: {$code} ({$host})\n";
    exit(0);
}

if ($command === 'page:create') {
    $siteCode = $options['site'] ?? 'main';
    $title = required($options, 'title');
    $slug = $options['slug'] ?? slugify($title);
    $content = $options['content'] ?? 'Hello from Zoosper.';

    $sites = new SiteRepository($pdo);
    $site = $sites->findByCode($siteCode);

    if ($site === null) {
        fwrite(STDERR, "Site does not exist: {$siteCode}\n");
        exit(1);
    }

    $pages = new PageRepository($pdo);
    $id = $pages->createPublished($site->id, $title, $slug, $content);

    echo "Created published page #{$id}: /{$slug}\n";
    exit(0);
}

echo "Zoosper CLI\n";
echo "Commands:\n";
echo "  migrate\n";
echo "  make:module Vendor_Module\n";
echo "  admin:create --email=admin@example.com --password='ChangeMe123!' --name='Admin User'\n";
echo "  site:create --code=main --name='Main Website' --host=127.0.0.1\n";
echo "  page:create --site=main --title='Home' --slug=home --content='Welcome to Zoosper.'\n";

/** @param list<string> $args @return array<string, string> */
function parseOptions(array $args): array
{
    $options = [];
    foreach ($args as $arg) {
        if (!str_starts_with($arg, '--') || !str_contains($arg, '=')) {
            continue;
        }
        [$key, $value] = explode('=', substr($arg, 2), 2);
        $options[$key] = $value;
    }
    return $options;
}

/** @param array<string, string> $options */
function required(array $options, string $key): string
{
    if (!array_key_exists($key, $options) || $options[$key] === '') {
        fwrite(STDERR, "Missing required option: --{$key}=...\n");
        exit(1);
    }
    return $options[$key];
}

function slugify(string $value): string
{
    $slug = preg_replace('/[^a-z0-9]+/i', '-', strtolower($value)) ?: 'page';
    return trim($slug, '-');
}
