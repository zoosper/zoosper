{* Theme override for zoosper-page::page/view. The body HTML is prepared by PageRenderer. *}
<article class="page page-{$page->slug}">
    <header class="page-header">
        <h1>{$page->title}</h1>
    </header>
    <div class="page-content">{($renderedContent ?? $page->content)|noescape}</div>
</article>
